GOOGLE_API_KEY=
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=forge-ai

# LLM Provider Configuration
LLM_PROVIDER=google
MODEL_NAME=gemini-1.5-flash

# OpenAI Configuration (Switch LLM_PROVIDER to 'openai' to use)
OPENAI_API_KEY=

# UML generation parallelism
# Set to 'true' when using a free-tier model with rate limits (5 req/min).
# Set to 'false' on paid plans to re-enable parallel diagram generation.
UML_SEQUENTIAL_GENERATION=false

# Maximum repair cycles per diagram before it is permanently marked VALIDATION_FAILED.
# Increase for complex diagrams; decrease to reduce LLM cost on failed diagrams.
MAX_UML_REPAIR_ATTEMPTS=2

# AI Quality Optimization
ENABLE_UML_REVIEW=false
ENABLE_FEW_SHOT=false
MIN_DIAGRAM_SCORE=9
